server {
    listen 80;
    server_name mmsafety.info www.mmsafety.info;

    # Якщо плануєте HTTPS — certbot додасть ще один блок
    #та автоматичний редирект; поки залишимо 80-порт.

    # --- СТАТИКА ---
    location /static/ {
        alias /var/www/mmsafety/Med/Med_visit/static/;
        access_log off;
        expires 30d;
    }

    location /media/ {
        alias /var/www/mmsafety/Med/Med_visit/media/;
        access_log off;
        expires 30d;
    }

    # --- DYNAMIC (Gunicorn) ---
    location / {
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_set_header Host             $host;
        proxy_set_header X-Real-IP        $remote_addr;

        proxy_pass http://unix:/run/med.sock;
    }

    access_log /var/log/nginx/mmsafety_access.log;
    error_log  /var/log/nginx/mmsafety_error.log;
}
